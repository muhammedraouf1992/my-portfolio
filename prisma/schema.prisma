// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String
  tag         String
  href        String
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
